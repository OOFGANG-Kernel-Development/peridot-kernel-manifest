<?xml version="1.0" encoding="UTF-8"?>
<manifest>
  <!-- ApexLegend007: all peridot kernel repos -->
  <remote fetch="https://github.com/OOFGANG-Kernel-Development" name="apex"/>
  <!-- AOSP: tools/mkbootimg -->
  <remote fetch="https://android.googlesource.com" name="aosp"/>

  <default remote="apex" sync-c="true" sync-tags="false"/>

  <!-- Root repo: contains build.sh, .bazelrc, WORKSPACE, MODULE.bazel, etc. -->
  <project remote="apex"
           name="sm8650-peridot-kernel"
           path="."
           revision="main"/>

  <!-- Kernel source (MiCode/Xiaomi_Kernel_OpenSource fork) -->
  <project remote="apex"
           name="peridot-msm-kernel"
           path="msm-kernel"
           revision="peridot-u-oss"
           clone-depth="1"/>

  <!-- Device tree source -->
  <project remote="apex"
           name="peridot-kernel-devicetree"
           path="msm-kernel/arch/arm64/boot/dts/vendor"
           revision="peridot-u-oss"
           clone-depth="1"/>

  <!-- Kleaf build framework (build/kernel/kleaf, hermetic tools, etc.) -->
  <project remote="apex"
           name="peridot-kernel-build"
           path="build/kernel"
           revision="peridot-u-oss"
           clone-depth="1"/>

  <!-- Bazel common rules (pkg_files, etc.) -->
  <project remote="apex"
           name="peridot-bazel-common-rules"
           path="build/bazel_common_rules"
           revision="android14-release"
           clone-depth="1"/>

  <!-- DTC: device-tree compiler, compiled from source by Bazel -->
  <project remote="apex"
           name="peridot-external-dtc"
           path="external/dtc"
           revision="master"
           clone-depth="1"/>

  <!-- Bazel Skylib: Starlark standard library -->
  <project remote="apex"
           name="peridot-external-bazel-skylib"
           path="external/bazel-skylib"
           revision="master"
           clone-depth="1"/>

  <!-- abseil-py: Python Abseil library (used by Kleaf Python tooling) -->
  <project remote="apex"
           name="peridot-external-absl-py"
           path="external/python/absl-py"
           revision="master"
           clone-depth="1"/>

  <!-- Stardoc: Bazel documentation generator (required by workspace.bzl) -->
  <project remote="apex"
           name="peridot-external-stardoc"
           path="external/stardoc"
           revision="main"
           clone-depth="1"/>

  <!-- Kernel prebuilt build-tools (avbtool, mkdtimg, depmod, etc.) -->
  <project remote="apex"
           name="peridot-kernel-prebuilts-build-tools"
           path="prebuilts/kernel-build-tools"
           revision="main"
           clone-depth="1"/>

  <!-- mkbootimg: creates boot/vendor_boot images -->
  <project remote="aosp"
           name="platform/system/tools/mkbootimg"
           path="tools/mkbootimg"
           revision="refs/heads/android14-release"
           clone-depth="1"/>

  <!--
    Vendor out-of-tree kernel modules:
    audio, bt, camera, display, graphics, IPA, rmnet, securemsm,
    wlan (cnss2/icnss2/qcacld-3.0), touch, video, eva, synx, spu, mm-drivers, etc.
  -->
  <project name="kernel_xiaomi_sm8650-modules"
           path="vendor"
           revision="main"
           clone-depth="1"/>

  <!--
    NOT managed by repo (set up automatically by build.sh):
      prebuilts/clang/host/linux-x86/clang-r487747c  (downloaded from AOSP)
      tools/bazel                                     (Bazelisk binary)
  -->
</manifest>
